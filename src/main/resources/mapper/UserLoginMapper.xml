<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="org.example.mapper.UserLoginMapper">
    <insert id="save" parameterType="org.example.entity.User">
        insert into user
        (phone, password, nickname, avatar,status, create_time, update_time)
        VALUES
        (#{phone},#{password},#{nickname},
        #{avatar},#{status},
        #{createTime},#{updateTime})
    </insert>
    <select id="getUser" resultType="org.example.entity.User" parameterType="org.example.entity.User">
    select * from user
    where phone=#{phone}
    </select>
</mapper>